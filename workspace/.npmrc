# Supply Chain Security: npm configuration
# See: https://docs.npmjs.com/cli/v11/using-npm/config

# postinstall 等のライフサイクルスクリプトを無効化
# マルウェアの主要な攻撃ベクトルをブロックする（axios 2026 等）
ignore-scripts=true

# バージョン範囲（^, ~）を使わず、正確なバージョンで保存
# 意図しないバージョン昇格を防止する
save-exact=true

# クールダウン: 公開から7日未満のバージョンをブロック（npm v11.10.0+）
# axios攻撃（公開〜悪用まで約3時間）を含む過去8年間の主要攻撃の
# 約半数をこの設定だけでブロック可能
# 緊急時のバイパス: npm install <pkg> --min-release-age=0
min-release-age=7

# インストール時に自動で npm audit を実行
audit=true

# audit で脆弱性が見つかった場合のしきい値
audit-level=moderate

# レジストリを公式のみに固定（dependency confusion 対策）
registry=https://registry.npmjs.org/

# パッケージの完全性検証を有効化
# package-lock.json のハッシュと照合する
package-lock=true
