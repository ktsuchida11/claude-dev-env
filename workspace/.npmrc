# Supply Chain Security: npm configuration
# See: https://docs.npmjs.com/cli/v10/using-npm/config

# postinstall 等のライフサイクルスクリプトを無効化
# マルウェアの主要な攻撃ベクトルをブロックする
ignore-scripts=true

# インストール時に自動で npm audit を実行
audit=true

# audit で脆弱性が見つかった場合のしきい値
audit-level=moderate

# レジストリを公式のみに固定（dependency confusion 対策）
registry=https://registry.npmjs.org/

# パッケージの完全性検証を有効化
# package-lock.json のハッシュと照合する
package-lock=true
