{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach to Frontend (Next.js)",
      "type": "node",
      "request": "attach",
      "port": 9230,
      "address": "frontend",
      "localRoot": "${workspaceFolder}/frontend",
      "remoteRoot": "/app",
      "restart": true,
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    },
    {
      "name": "Attach to Backend (FastAPI)",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "backend",
        "port": 5678
      },
      "pathMappings": [
        {
          "localRoot": "${workspaceFolder}/backend",
          "remoteRoot": "/app"
        }
      ],
      "justMyCode": true
    }
  ],
  "compounds": [
    {
      "name": "Attach to Frontend + Backend",
      "configurations": [
        "Attach to Frontend (Next.js)",
        "Attach to Backend (FastAPI)"
      ]
    }
  ]
}
