# === 外部 GitLab 版 .env テンプレート ===
# docker-compose.external-gitlab.yml 用
#
# 使い方:
#   cp .devcontainer/.env.external-gitlab.example .env
#   # .env を編集して値を設定

# === Required for Phase 1 ===
OPENAI_API_KEY=sk-your-openai-api-key
LITELLM_MASTER_KEY=sk-litellm-master-key-change-me

# === Anthropic (直接接続) ===
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# === Phase 2: Azure OpenAI ===
# AZURE_DEPLOYMENT_NAME=gpt-5-mini
# AZURE_API_KEY=your-azure-api-key
# AZURE_API_BASE=https://your-resource.openai.azure.com/
# AZURE_API_VERSION=2025-04-01-preview

# === Phase 3: Azure Databricks (Claude External Model) ===
# DATABRICKS_API_KEY=dapi-your-databricks-token
# DATABRICKS_API_BASE=https://adb-xxxx.xx.azuredatabricks.net/serving-endpoints

# === External GitLab ===
# 外部 GitLab インスタンスの URL と Personal Access Token
GITLAB_HOST=https://gitlab.example.com
GITLAB_PERSONAL_ACCESS_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# === OpenHands ===
# OpenHands を有効にする場合は docker compose --profile openhands で起動
# WORKSPACE_MOUNT_PATH にはホスト上の workspace-openhands の絶対パスを指定
# OPENHANDS_WORKSPACE_MOUNT_PATH=/absolute/path/to/m_poc/workspace-openhands

# === Firewall ===
# dev コンテナのファイアウォール (init-firewall.sh) の ON/OFF
# プロキシ環境での切り分けや Context7 利用時に false に設定
# ENABLE_FIREWALL=false

# === Proxy Settings ===
# 社内プロキシ環境で利用する場合にコメントを外して設定
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
# NO_PROXY=localhost,127.0.0.1,litellm,dev,api.openai.com,*.openai.azure.com,*.cognitiveservices.azure.com,*.azuredatabricks.net,api.anthropic.com
#
# 外部 GitLab を NO_PROXY に含めるかはネットワーク構成による:
# - GitLab にプロキシなしで直接アクセス可能 → NO_PROXY に GitLab ホストを追加
#   例: NO_PROXY=localhost,127.0.0.1,litellm,dev,gitlab.example.com,...
# - GitLab にプロキシ経由でのみアクセス可能 → NO_PROXY に含めない
#
# Windows 環境での注意:
# - NO_PROXY のワイルドカード (*.example.com) が動作しない場合は
#   ドット始まり (.example.com) に置き換える
# - Docker Desktop → Settings → Resources → Proxies で別途設定が必要な場合がある
