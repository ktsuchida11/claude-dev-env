# === Required for Phase 1 ===
OPENAI_API_KEY=sk-your-openai-api-key
LITELLM_MASTER_KEY=sk-litellm-master-key-change-me

# === Phase 2: Azure OpenAI ===
# Azure ポータル → Azure OpenAI リソース → キーとエンドポイント で確認
# AZURE_DEPLOYMENT_NAME=gpt-5-mini
# AZURE_API_KEY=your-azure-api-key
# AZURE_API_BASE=https://your-resource.openai.azure.com/
# AZURE_API_VERSION=2025-04-01-preview

# === Phase 3: Azure Databricks (Claude External Model) ===
# Databricks の External Model で Anthropic API をプロキシ利用
# Anthropic API キーは Databricks Serving のエンドポイント設定画面で登録
# Databricks ワークスペース → Settings → Developer → Access tokens で PAT を生成
# DATABRICKS_API_KEY=dapi-your-databricks-token
# DATABRICKS_API_BASE=https://adb-xxxx.xx.azuredatabricks.net/serving-endpoints

# === GitLab CE ===
GITLAB_ROOT_PASSWORD=P@ssw0rd1234
# GITLAB_PERSONAL_ACCESS_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# === Proxy Settings ===
# 社内プロキシ環境で利用する場合にコメントを外して設定
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
# NO_PROXY=localhost,127.0.0.1,litellm,gitlab,gitlab-runner,dev,api.openai.com,*.openai.azure.com,*.cognitiveservices.azure.com,*.azuredatabricks.net,api.anthropic.com
#
# Windows 環境での注意:
# - Docker Desktop for Windows では NO_PROXY のワイルドカード (*.example.com) が
#   正しく解釈されない場合がある。その場合はドメインを個別に列挙する:
# NO_PROXY=localhost,127.0.0.1,litellm,gitlab,gitlab-runner,dev,api.openai.com,.openai.azure.com,.cognitiveservices.azure.com,.azuredatabricks.net,api.anthropic.com
#   (".openai.azure.com" のようにドット始まりで指定するとサブドメイン全体にマッチする)
#
# - Windows のシステム環境変数に HTTP_PROXY / HTTPS_PROXY が設定されていると
#   Docker Desktop 自体の通信(イメージ pull 等)にも影響する。
#   Docker Desktop → Settings → Resources → Proxies で個別に設定するか、
#   システム環境変数側で Docker 関連の通信を NO_PROXY に含めること。
#
# NO_PROXY の設定について:
# - Docker 内部通信 (litellm, gitlab 等) はプロキシを経由しない
# - LLM API への通信をプロキシ経由にするかはネットワーク構成による
# - 直接アクセス可能な場合は NO_PROXY に API エンドポイントを含める（上記デフォルト）
# - プロキシ経由でのみアクセス可能な場合は NO_PROXY から API エンドポイントを除外する
