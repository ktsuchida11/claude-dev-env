{
  "context7": {
    "type": "stdio",
    "command": "npx",
    "args": ["-y", "@upstash/context7-mcp@2.1.8"],
    "env": {}
  },
  "playwright": {
    "type": "stdio",
    "command": "npx",
    "args": ["-y", "@playwright/mcp@0.0.70"],
    "env": {}
  },
  "serena": {
    "type": "stdio",
    "command": "uvx",
    "args": [
      "--from", "git+https://github.com/oraios/serena@1e6345cae95bd48201a614e5b7d1537df55c7533",
      "serena", "start-mcp-server",
      "--context", "claude-code",
      "--project-from-cwd"
    ],
    "env": {}
  }
}
