ENABLE_JAVA=
# 指定のポート以外は通さないように設定する
FIREWALL_ALLOWED_PORTS=

# === Required ===
OPENAI_API_KEY=
LITELLM_MASTER_KEY=

# === Anthropic (直接接続) ===
ANTHROPIC_API_KEY=

# === LangFuse (Claude Code トレーシング) ===
# Claude Code の会話・ツール使用を LangFuse に送信してモニタリング
# true に設定すると有効化、未設定 or false で無効
TRACE_TO_LANGFUSE=
#
# CC_LANGFUSE_* は Claude Code Hook 専用の変数。
# アプリ側の LANGFUSE_* と同じ LangFuse インスタンスを使う場合でも、
# プロジェクト/キーを分けることを推奨（トレースが混在するため）。
CC_LANGFUSE_SECRET_KEY=
CC_LANGFUSE_PUBLIC_KEY=
CC_LANGFUSE_BASE_URL=
# デバッグログ (true で ~/.claude/state/langfuse_hook.log に詳細出力)
CC_LANGFUSE_DEBUG=

# Laugfuseがローカルにある場合はこのせってが必要
#COMPOSE_FILE=docker-compose.yml:docker-compose.langfuse.yml 