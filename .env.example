# === Required ===
OPENAI_API_KEY=sk-your-openai-api-key
LITELLM_MASTER_KEY=sk-litellm-master-key-change-me

# === Anthropic (直接接続) ===
# Anthropic API キー (https://console.anthropic.com → API Keys)
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# === GitHub ===
# GitHub Personal Access Token (https://github.com/settings/tokens)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# === Java ===
# Java 環境 (JDK, Maven, Gradle, JDTLS) のインストール ON/OFF
# Java を使わないプロジェクトでは false にするとビルドが高速化される
# ENABLE_JAVA=false

# === LangFuse (Claude Code トレーシング) ===
# Claude Code の会話・ツール使用を LangFuse に送信してモニタリング
# true に設定すると有効化、未設定 or false で無効
# TRACE_TO_LANGFUSE=true
#
# CC_LANGFUSE_* は Claude Code Hook 専用の変数。
# アプリ側の LANGFUSE_* と同じ LangFuse インスタンスを使う場合でも、
# プロジェクト/キーを分けることを推奨（トレースが混在するため）。
# CC_LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxx
# CC_LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxx
# CC_LANGFUSE_BASE_URL=https://cloud.langfuse.com
# デバッグログ (true で ~/.claude/state/langfuse_hook.log に詳細出力)
# CC_LANGFUSE_DEBUG=true
#
# === LangFuse (アプリ用) ===
# ⚠ 注意: 以下の LANGFUSE_* をここで設定すると、コンテナ環境変数として注入され、
# アプリ側の .env ファイルの値を上書きします（pydantic-settings 等は環境変数を優先）。
# アプリが独自に .env で LANGFUSE_* を管理している場合は、ここではなく
# アプリ側の .env で設定してください。
#
# ここで設定するケース: アプリ側に .env がなく、環境変数で渡したい場合のみ。
# LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxx
# LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxx
# LANGFUSE_BASE_URL=http://host.docker.internal:3000
# LANGFUSE_HOST=http://host.docker.internal:3000

# === Docker Compose ファイル構成 ===
# LangFuse (セルフホスト) を利用する場合、dev コンテナを langfuse_default ネットワークに
# 接続して langfuse-web:3000 で直接通信できるようにする。
# LangFuse が未起動の場合はコメントアウトすること（起動エラーになるため）。
# COMPOSE_FILE=docker-compose.yml:docker-compose.langfuse.yml

# === Supply Chain Guard ===
# パッケージインストール時のサプライチェーン攻撃対策 (デフォルト: 有効)
# typosquatting 検知、lockfile チェック、脆弱性監査を自動実行
# ENABLE_SUPPLY_CHAIN_GUARD=false

# === Firewall ===
# dev コンテナのファイアウォール (init-firewall.sh) の ON/OFF
# プロキシ環境での切り分け等に false に設定
# ENABLE_FIREWALL=false

# host.docker.internal 経由でホスト側サービス (Streamlit, LangFuse 等) へ
# アクセスを許可するポート（カンマ区切り）
# FIREWALL_ALLOWED_PORTS=443,80,3000,8501

# === Proxy Settings ===
# 社内プロキシ環境で利用する場合にコメントを外して設定
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
# NO_PROXY=localhost,127.0.0.1,litellm,dev,api.openai.com,api.anthropic.com
#
# Windows 環境での注意:
# - Docker Desktop for Windows では NO_PROXY のワイルドカード (*.example.com) が
#   正しく解釈されない場合がある。その場合はドメインを個別に列挙する
# - Windows のシステム環境変数に HTTP_PROXY / HTTPS_PROXY が設定されていると
#   Docker Desktop 自体の通信(イメージ pull 等)にも影響する。
#   Docker Desktop → Settings → Resources → Proxies で個別に設定するか、
#   システム環境変数側で Docker 関連の通信を NO_PROXY に含めること。
#
# NO_PROXY の設定について:
# - Docker 内部通信 (litellm 等) はプロキシを経由しない
# - LLM API への通信をプロキシ経由にするかはネットワーク構成による
# - 直接アクセス可能な場合は NO_PROXY に API エンドポイントを含める（上記デフォルト）
# - プロキシ経由でのみアクセス可能な場合は NO_PROXY から API エンドポイントを除外する
