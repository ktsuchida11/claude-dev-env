[Unit]
Description=Zui Security Check (weekly supply chain audit)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/bin/bash -l __HOME__/bin/linux-supply-chain-check.sh
StandardOutput=append:__HOME__/security-reports/systemd-stdout.log
StandardError=append:__HOME__/security-reports/systemd-stderr.log
