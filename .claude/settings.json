{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Bash(git *)",
      "Bash(npm run *)",
      "Bash(npm install *)",
      "Bash(npm uninstall *)",
      "Bash(npm test *)",
      "Bash(npm exec *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(uv *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pip *)",
      "Bash(gradle *)",
      "Bash(mvn *)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh repo view *)",
      "Bash(gh repo list *)",
      "Bash(gh repo clone *)",
      "Bash(gh run *)",
      "Bash(gh release view *)",
      "Bash(gh release list *)",
      "Bash(gh auth status)",
      "Bash(gh label *)",
      "Bash(gh search *)",
      "Bash(gh browse *)",
      "Bash(make *)",
      "Bash(docker compose *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(diff *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(echo *)",
      "Bash(cd *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(env)",
      "Bash(printenv *)",
      "Bash(tree *)",
      "Bash(jq *)",
      "Bash(ruff *)",
      "Bash(mypy *)",
      "Bash(pytest *)",
      "Bash(tsc *)",
      "Bash(eslint *)",
      "Bash(prettier *)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(find * -delete)",
      "Bash(find * -exec rm *)",
      "Bash(find * -exec shred *)",
      "Bash(* xargs rm *)",
      "Bash(* xargs shred *)",
      "Bash(* | xargs rm *)",
      "Bash(* | xargs shred *)",
      "Bash(* sed -i * settings.json*)",
      "Bash(* sed -i * .claude.json*)",
      "Bash(* sed -i * .mcp.json*)",
      "Bash(gh api *)",
      "Bash(gh auth token*)",
      "Bash(gh auth login*)",
      "Bash(gh auth logout*)",
      "Bash(gh auth refresh*)",
      "Bash(gh secret *)",
      "Bash(gh variable *)",
      "Bash(gh workflow run*)",
      "Bash(gh workflow enable*)",
      "Bash(gh workflow disable*)",
      "Bash(gh ssh-key *)",
      "Bash(gh gpg-key *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(nc *)",
      "Bash(ncat *)",
      "Bash(telnet *)",
      "Bash(ftp *)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(chmod 666 *)",
      "Bash(chmod -R 777 *)",
      "Bash(chmod -R 666 *)",
      "Bash(chmod u+s *)",
      "Bash(chmod g+s *)",
      "Bash(chmod +s *)",
      "Bash(chmod 4* *)",
      "Bash(chmod 2* *)",
      "Bash(chmod 6* *)",
      "Bash(eval *)",
      "Bash(exec *)",
      "Bash(nohup *)",
      "Bash(crontab *)",
      "Bash(python -c *import*socket*)",
      "Bash(python3 -c *import*socket*)",
      "Read(.env)",
      "Read(.env.*)",
      "Write(.env)",
      "Write(.env.*)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Write(.claude/hooks/**)",
      "Edit(.claude/hooks/**)",
      "Write(.claude/settings.json)",
      "Edit(.claude/settings.json)",
      "Write(.claude/settings.local.json)",
      "Edit(.claude/settings.local.json)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Read(/etc/shadow)",
      "Read(/etc/gshadow)",
      "Read(./secrets/**)",
      "WebFetch"
    ],
    "disableBypassPermissionsMode": "disable"
  },

  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": [
      "docker *",
      "gh *"
    ],
    "filesystem": {
      "allowWrite": [
        "/Users/tsuchitakouji/pg_work_space/claude_test/cldev-book/workspace",
        "~/.npm",
        "~/.cache",
        "~/.local",
        "~/.m2/repository",
        "~/.gradle",
        "/tmp"
      ],
      "denyWrite": [
        "/Users/tsuchitakouji/pg_work_space/claude_test/cldev-book/.claude/settings.json",
        "/Users/tsuchitakouji/pg_work_space/claude_test/cldev-book/.claude/settings.local.json",
        "/Users/tsuchitakouji/pg_work_space/claude_test/cldev-book/.claude/hooks",
        "/Users/tsuchitakouji/pg_work_space/claude_test/cldev-book/.claude/skills",
        "/etc"
      ],
      "denyRead": [
        "~/.ssh",
        "~/.aws",
        "~/.gnupg"
      ]
    },
    "network": {
      "allowedDomains": [
        "github.com",
        "*.github.com",
        "*.githubusercontent.com",
        "registry.npmjs.org",
        "*.npmjs.org",
        "registry.yarnpkg.com",
        "raw.githubusercontent.com",
        "codeload.github.com",
        "objects.githubusercontent.com",
        "pypi.org",
        "files.pythonhosted.org",
        "api.anthropic.com",
        "claude.ai",
        "api.openai.com",
        "openaipublic.blob.core.windows.net",
        "oauth2.googleapis.com",
        "accounts.google.com",
        "www.googleapis.com",
        "context7.com",
        "*.context7.com",
        "cloud.langfuse.com",
        "us.cloud.langfuse.com"
      ],
      "allowLocalBinding": true,
      "allowAllUnixSockets": false
    }
  },

  "enableAllProjectMcpServers": false,
  "enabledMcpjsonServers": [
    "context7",
    "playwright",
    "serena"
  ],

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/block-dangerous.sh"
          },
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/supply-chain-guard.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/dockerfile-cooldown-check.sh --pre"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/dockerfile-cooldown-check.sh --pre"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/lint-on-save.sh"
          },
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/dockerfile-cooldown-check.sh"
          },
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/gha-security-check.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/dockerfile-cooldown-check.sh"
          },
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/gha-security-check.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/supply-chain-audit.sh"
          },
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/env-plaintext-guard.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 $CLAUDE_PROJECT_DIR/.claude/hooks/langfuse_hook.py"
          }
        ]
      }
    ]
  },

  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "PIP_CONFIG_FILE": "/Users/tsuchitakouji/pg_work_space/claude_test/cldev-book/workspace/.pip.conf"
  }
}
