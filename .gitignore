# === 機密情報 ===
.env
.env.local
.env.keys
*.decrypted
*.tmp.env

# === .env 暗号化関連 ===
# .env.enc（暗号化済み）と .env.example はコミット OK
!.env.enc
!.env.example

# === ローカル設定 ===
.DS_Store
.claude/settings.local.json

# === ログ・キャッシュ ===
*.log

# === .claude/ — ルートが正（hooks, tests, settings.json を git 管理） ===
# ※ .claude/ 自体は追跡対象（ホスト Mac 用設定 + ポータブル hooks/tests）

# === workspace 管理 ===
# workspace 全体を除外し、必要なファイルのみ追跡
workspace/*

# workspace/.mcp.json を追跡
!workspace/.mcp.json

# workspace/.claude/ — settings.json のみ追跡（コンテナ用パス）
# hooks と tests は .claude/ が正。DevContainer 起動時にコピーされる
!workspace/.claude/
workspace/.claude/*
!workspace/.claude/settings.json
workspace/.claude/hooks/
workspace/.claude/tests/
workspace/.claude/state/

# workspace 直下のサプライチェーン対策設定ファイルを追跡
!workspace/.npmrc
!workspace/.pip.conf
!workspace/.mvn-settings.xml
!workspace/uv.toml

# workspace/CLAUDE.md を追跡
!workspace/CLAUDE.md

# workspace のキャッシュ・一時ファイルは除外
workspace/.playwright-mcp/
workspace/.uv-cache/

# === ホスト側ツール（追跡対象） ===
# cooldown_management/ を追跡
!cooldown_management/

# mac_security_check/ を追跡（ホスト Mac セキュリティツール群）
!mac_security_check/
