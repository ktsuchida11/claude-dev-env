# === 機密情報 ===
.env
.env.local

# === ローカル設定（git管理外） ===
.claude/
.DS_Store

# === ログ・キャッシュ ===
*.log

# === workspace 管理 ===
# workspace全体を除外し、必要なファイルのみ追跡
workspace/*

# workspace/.mcp.json を追跡
!workspace/.mcp.json

# workspace/.claude/ を段階的に開放
!workspace/.claude/
workspace/.claude/*
!workspace/.claude/settings.json
!workspace/.claude/hooks/
!workspace/.claude/tests/

# workspace/.claude/ のランタイム状態は除外
workspace/.claude/state/

# workspace直下のサプライチェーン対策設定ファイルを追跡
!workspace/.npmrc
!workspace/.pip.conf
!workspace/.mvn-settings.xml
!workspace/uv.toml

# workspace/CLAUDE.md を追跡
!workspace/CLAUDE.md

# workspace のキャッシュ・一時ファイルは除外
workspace/.playwright-mcp/
workspace/.uv-cache/

# === ホスト側ツール（追跡対象） ===
# cooldown_management/ を追跡
!cooldown_management/

# mac_security_check/ を追跡（ホスト Mac セキュリティツール群）
!mac_security_check/
